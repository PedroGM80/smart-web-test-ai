# ── Ollama (AI stack, only needed for real runs; --dry-run works without) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_VISION_MODEL=llava

# ── Playwright ──
HEADLESS=true
BROWSER=chromium

# ── Paths ──
SCREENSHOTS_DIR=./screenshots
REPORTS_DIR=./reports

# ── Database (default: local SQLite; set PostgreSQL URL for production) ──
DATABASE_URL=sqlite:///./smarttest.db
ECHO_SQL=false

# ── Optional integrations (leave empty to disable) ──
# Slack incoming webhook for test notifications
SLACK_WEBHOOK_URL=

# Email reports (SMTP). For Gmail use an app password, never your real one.
SENDER_EMAIL=
SENDER_PASSWORD=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# GitHub auto-issues on failures (repo as owner/name, token with repo scope)
GITHUB_REPO=
GITHUB_TOKEN=
